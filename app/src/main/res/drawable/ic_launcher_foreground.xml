<?xml version="1.0" encoding="utf-8"?>
<!-- "NT" monogram, built from plain rectangles rather than font glyphs so it renders identically
     everywhere. Also reused as the monochrome/themed-icon layer (see ic_launcher.xml) - a flat
     white shape on transparent works directly for that without a separate asset. Content is kept
     within the adaptive-icon safe zone (a 66dp circle centered at 54,54; farthest corner here is
     ~31.8dp from center) so it isn't clipped by circular/squircle/rounded-square launcher masks. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- N -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M31,32 L37,32 L37,76 L31,76 Z
                           M45,32 L51,32 L51,76 L45,76 Z
                           M31,32 L37,32 L51,76 L45,76 Z" />
    <!-- T -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M57,32 L77,32 L77,38 L57,38 Z
                           M64,38 L70,38 L70,76 L64,76 Z" />
</vector>
